<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Description>An Aspire hosting integration to run the MCP Inspector against a Model Context Protocol (MCP) server.</Description>
    <AdditionalPackageTags>ai mcp debugging hosting</AdditionalPackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Aspire.Hosting" />
    <PackageReference Include="Aspire.Hosting.JavaScript" />
    <PackageReference Include="AspNetCore.HealthChecks.Uris" />
    <PackageReference Include="MessagePack" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="$(SharedDir)\LoggingUtils.cs" Link="LoggingUtils.cs" />
  </ItemGroup>

</Project>
