<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <Description>An Aspire hosting integration that imports existing Docker Compose files into the Aspire resource graph.</Description>
    <AdditionalPackageTags>hosting compose docker docker-compose yaml</AdditionalPackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Aspire.Hosting" />
    <PackageReference Include="YamlDotNet" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\CommunityToolkit.Aspire.Hosting.Compose.Generator\CommunityToolkit.Aspire.Hosting.Compose.Generator.csproj"
                      OutputItemType="Analyzer"
                      ReferenceOutputAssembly="false" />
  </ItemGroup>

  <ItemGroup>
    <None Include="build\**\*" Pack="true" PackagePath="build" />
    <None Include="..\CommunityToolkit.Aspire.Hosting.Compose.Generator\bin\$(Configuration)\net10.0\CommunityToolkit.Aspire.Hosting.Compose.Generator.dll" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="CommunityToolkit.Aspire.Hosting.Compose.Tests" />
  </ItemGroup>

</Project>
