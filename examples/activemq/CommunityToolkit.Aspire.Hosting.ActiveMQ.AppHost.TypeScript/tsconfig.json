{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true
  },
  "include": [
    "apphost.mts",
    ".aspire/modules/**/*.ts",
    ".aspire/modules/**/*.d.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}